<svg width="100%" viewBox="0 0 680 585.11" role="img" xmlns="http://www.w3.org/2000/svg">
  <title style="fill:rgb(0, 0, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">thing. Android Architecture Diagram</title>
  <desc style="fill:rgb(0, 0, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Layered 3D Android architecture: UI, ViewModel, Data, Firebase layers with thing. branding</desc>
  <defs>
    <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>

    <!-- Layer shadow filters -->
    <filter id="layerShadow" x="-10%" y="-10%" width="130%" height="140%">
      <feDropShadow dx="6" dy="8" stdDeviation="4" flood-color="rgba(0,0,0,0.18)"/>
    </filter>
    <filter id="topShadow" x="-5%" y="-5%" width="120%" height="130%">
      <feDropShadow dx="3" dy="4" stdDeviation="3" flood-color="rgba(0,0,0,0.12)"/>
    </filter>
  </defs>

  <!-- ─── LAYER 4: Firebase (bottom, deepest) ─── -->
  <!-- Side face (right) -->
  <polygon points="536,470 580,448 580,510 536,532" fill="#0f1a2e" opacity="0.9" style="fill:rgb(15, 26, 46);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Bottom face -->
  <polygon points="100,532 536,532 580,510 144,510" fill="#162236" opacity="0.85" style="fill:rgb(22, 34, 54);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Top face -->
  <rect x="100" y="470" width="436" height="62" rx="0" fill="#1a2f4a" filter="url(#layerShadow)" style="fill:rgb(26, 47, 74);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Top face left edge illusion -->
  <polygon points="100,470 144,448 580,448 536,470" fill="#1e3655" style="fill:rgb(30, 54, 85);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Actual top surface -->
  <rect x="100" y="448" width="436" height="62" rx="4" fill="#1e3a5f" style="fill:rgb(30, 58, 95);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Gradient overlay for depth -->
  <rect x="100" y="448" width="436" height="10" rx="4" fill="white" opacity="0.05" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.05;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Layer label -->
  <text x="136" y="473" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#4a9eff" letter-spacing="1.5" opacity="0.9" style="fill:rgb(74, 158, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:system-ui, sans-serif;font-size:11px;font-weight:600;text-anchor:start;dominant-baseline:auto">FIREBASE — REMOTE SERVICES</text>
  <text x="136" y="490" font-family="system-ui,sans-serif" font-size="12" fill="#7ab8ff" opacity="0.85" style="fill:rgb(122, 184, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:system-ui, sans-serif;font-size:12px;font-weight:400;text-anchor:start;dominant-baseline:auto">Firestore  ·  Auth  ·  Storage  ·  Crashlytics</text>
  <!-- Badge -->
  <rect x="488" y="456" width="34" height="18" rx="9" fill="#4a9eff" opacity="0.25" style="fill:rgb(74, 158, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.25;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="505" y="469" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#4a9eff" text-anchor="middle" style="fill:rgb(74, 158, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">FB</text>

  <!-- ─── LAYER 3: Data ─── -->
  <!-- Side face (right) -->
  <polygon points="524,372 568,350 568,414 524,436" fill="#1a2a1a" opacity="0.9" style="fill:rgb(26, 42, 26);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Bottom face -->
  <polygon points="88,436 524,436 568,414 132,414" fill="#1e301e" opacity="0.85" style="fill:rgb(30, 48, 30);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Top face illusion -->
