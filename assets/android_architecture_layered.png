  <!-- Actual top surface -->
  <rect x="88" y="350" width="436" height="62" rx="4" fill="#2d5c2d" style="fill:rgb(45, 92, 45);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect x="88" y="350" width="436" height="10" rx="4" fill="white" opacity="0.05" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.05;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Layer label -->
  <text x="124" y="375" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#6dcc6d" letter-spacing="1.5" opacity="0.9" style="fill:rgb(109, 204, 109);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:system-ui, sans-serif;font-size:11px;font-weight:600;text-anchor:start;dominant-baseline:auto">DATA LAYER</text>
  <text x="124" y="393" font-family="system-ui,sans-serif" font-size="12" fill="#9de89d" opacity="0.85" style="fill:rgb(157, 232, 157);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:system-ui, sans-serif;font-size:12px;font-weight:400;text-anchor:start;dominant-baseline:auto">Firestore Repository  ·  Local Cache  ·  Firebase Storage</text>
  <!-- Badge -->
  <rect x="476" y="358" width="34" height="18" rx="9" fill="#6dcc6d" opacity="0.25" style="fill:rgb(109, 204, 109);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.25;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="493" y="371" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#6dcc6d" text-anchor="middle" style="fill:rgb(109, 204, 109);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">DATA</text>

  <!-- ─── LAYER 2: ViewModel ─── -->
  <!-- Side face (right) -->
  <polygon points="512,274 556,252 556,316 512,338" fill="#2a1f0e" opacity="0.9" style="fill:rgb(42, 31, 14);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Bottom face -->
  <polygon points="76,338 512,338 556,316 120,316" fill="#33260f" opacity="0.85" style="fill:rgb(51, 38, 15);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Top face illusion -->
  <polygon points="76,274 120,252 556,252 512,274" fill="#4a3510" style="fill:rgb(74, 53, 16);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Actual top surface -->
  <rect x="76" y="252" width="436" height="62" rx="4" fill="#5a4212" style="fill:rgb(90, 66, 18);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect x="76" y="252" width="436" height="10" rx="4" fill="white" opacity="0.05" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.05;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Layer label -->
  <text x="112" y="277" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#f0a830" letter-spacing="1.5" opacity="0.9" style="fill:rgb(240, 168, 48);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:system-ui, sans-serif;font-size:11px;font-weight:600;text-anchor:start;dominant-baseline:auto">VIEWMODEL LAYER</text>
  <text x="112" y="295" font-family="system-ui,sans-serif" font-size="12" fill="#f5c870" opacity="0.85" style="fill:rgb(245, 200, 112);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:system-ui, sans-serif;font-size:12px;font-weight:400;text-anchor:start;dominant-baseline:auto">ViewModels  ·  LiveData  ·  Lifecycle-aware State</text>
  <!-- Badge -->
  <rect x="464" y="260" width="34" height="18" rx="9" fill="#f0a830" opacity="0.25" style="fill:rgb(240, 168, 48);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.25;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="481" y="273" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#f0a830" text-anchor="middle" style="fill:rgb(240, 168, 48);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">VM</text>

  <!-- ─── LAYER 1: UI (top, closest) ─── -->
  <!-- Side face (right) -->
  <polygon points="500,176 544,154 544,218 500,240" fill="#2e1a2e" opacity="0.9" style="fill:rgb(46, 26, 46);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Bottom face -->
  <polygon points="64,240 500,240 544,218 108,218" fill="#3a2040" opacity="0.85" style="fill:rgb(58, 32, 64);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Top face illusion -->
