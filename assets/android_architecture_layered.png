  <text x="104" y="73" font-family="system-ui,sans-serif" font-size="9" fill="var(--color-text-secondary)" letter-spacing="2.5" style="fill:rgb(194, 192, 182);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:9px;font-weight:400;text-anchor:start;dominant-baseline:auto">HOME FURNITURE MARKETPLACE</text>

  <!-- Title right -->
  <text x="636" y="48" font-family="system-ui,sans-serif" font-size="13" font-weight="500" fill="var(--color-text-primary)" text-anchor="end" style="fill:rgb(250, 249, 245);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:13px;font-weight:500;text-anchor:end;dominant-baseline:auto">Android Architecture</text>
  <text x="636" y="66" font-family="system-ui,sans-serif" font-size="11" fill="var(--color-text-secondary)" text-anchor="end" style="fill:rgb(194, 192, 182);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:11px;font-weight:400;text-anchor:end;dominant-baseline:auto">MVVM + Firebase</text>

  <!-- Separator line -->
