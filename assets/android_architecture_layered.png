  <!-- Actual top surface -->
  <rect x="64" y="154" width="436" height="62" rx="4" fill="#673580" style="fill:rgb(103, 53, 128);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect x="64" y="154" width="436" height="10" rx="4" fill="white" opacity="0.07" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.07;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Layer label -->
  <text x="100" y="179" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#cc88ff" letter-spacing="1.5" opacity="0.9" style="fill:rgb(204, 136, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:system-ui, sans-serif;font-size:11px;font-weight:600;text-anchor:start;dominant-baseline:auto">UI LAYER</text>
  <text x="100" y="197" font-family="system-ui,sans-serif" font-size="12" fill="#ddaaff" opacity="0.85" style="fill:rgb(221, 170, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:system-ui, sans-serif;font-size:12px;font-weight:400;text-anchor:start;dominant-baseline:auto">Activities  ·  Fragments  ·  RecyclerView  ·  Navigation</text>
  <!-- Badge -->
  <rect x="452" y="162" width="34" height="18" rx="9" fill="#cc88ff" opacity="0.25" style="fill:rgb(204, 136, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.25;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="469" y="175" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#cc88ff" text-anchor="middle" style="fill:rgb(204, 136, 255);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">UI</text>

  <!-- ─── DOWN ARROWS between layers ─── -->
  <!-- UI → VM -->
  <line x1="282" y1="218" x2="282" y2="250" stroke="#cc88ff" stroke-width="1.5" stroke-opacity="0.5" marker-end="url(#arrow)" style="fill:rgb(0, 0, 0);stroke:rgb(204, 136, 255);color:rgb(255, 255, 255);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- VM → Data -->
  <line x1="282" y1="316" x2="282" y2="348" stroke="#f0a830" stroke-width="1.5" stroke-opacity="0.5" marker-end="url(#arrow)" style="fill:rgb(0, 0, 0);stroke:rgb(240, 168, 48);color:rgb(255, 255, 255);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Data → Firebase -->
  <line x1="282" y1="414" x2="282" y2="446" stroke="#6dcc6d" stroke-width="1.5" stroke-opacity="0.5" marker-end="url(#arrow)" style="fill:rgb(0, 0, 0);stroke:rgb(109, 204, 109);color:rgb(255, 255, 255);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

