<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="h4">
        <item name="android:fontFamily">@font/inter_18pt_bold</item>
        <item name="android:textColor">@color/g_black</item>
        <item name="android:textSize">@dimen/h4TextSize</item>
    </style>

    <style name="h2">
        <item name="android:fontFamily">@font/inter_18pt_regular</item>
        <item name="android:textColor">@color/g_black</item>
        <item name="android:textSize">@dimen/h2TextSize</item>
    </style>

    <style name="h3">
        <item name="android:fontFamily">@font/inter_18pt_medium</item>
        <item name="android:textColor">@color/g_black</item>
        <item name="android:textSize">@dimen/h3TextSize</item>
    </style>

    <style name="blackButtonStyle">
        <item name="android:background">@drawable/black_background</item>
        <item name="android:fontFamily">@font/inter_18pt_semibold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/h2TextSize</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="whiteButtonStyle">
        <item name="android:background">@drawable/white_background</item>
        <item name="android:fontFamily">@font/inter_18pt_semibold</item>
        <item name="android:textColor">@color/g_black</item>
        <item name="android:textSize">@dimen/h2TextSize</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="editText">
        <item name="android:background">@drawable/white_background</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:inputType">text</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">@font/inter_18pt_regular</item>
        <item name="android:textColor">@color/g_black</item>
        <item name="android:textColorHint">#99000000</item>
    </style>

    <dimen name="h4TextSize">35sp</dimen>
    <dimen name="h2TextSize">17sp</dimen>
    <dimen name="h3TextSize">22sp</dimen>

    <style name="DialogStyle" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowSoftInputMode">adjustResize</item>

    </style>

    <style name="tabLayout_text" parent="TextAppearance.AppCompat">
        <item name="color">@color/black</item>
        <item name="fontFamily">@font/inter_18pt_bold</item>
        <item name="textAllCaps">false</item>
        <item name="android:textStyle">bold</item>

    </style>

</resources>
