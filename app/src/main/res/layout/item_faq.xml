<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/faqItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/card_white_background"
    android:elevation="2dp"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <LinearLayout
        android:id="@+id/layoutQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <ImageView
            android:id="@+id/ivFaqIcon"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_help_outline"
            android:background="@drawable/settings_items_background"
            android:backgroundTint="#007AFF"
            android:padding="8dp"
            app:tint="@color/white"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/inter_18pt_medium"
            android:textSize="14sp"
            android:textColor="#222222" />

        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_arrow"
            android:rotation="90"
            app:tint="#CCCCCC"
            android:contentDescription="@null" />

    </LinearLayout>

    <View
        android:id="@+id/dividerFaq"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#EEEEEE"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="14dp"
        android:fontFamily="@font/inter_18pt_regular"
        android:textSize="13sp"
        android:textColor="#555555"
        android:lineSpacingMultiplier="1.4"
        android:visibility="gone" />

</LinearLayout>
