<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFDBB1" /> <!-- Saturated Orange -->
            <corners android:radius="20dp" />
            <stroke android:width="1.5dp" android:color="@color/status_confirmed" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/status_confirmed_bg" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="@color/status_confirmed" />
        </shape>
    </item>
</selector>
