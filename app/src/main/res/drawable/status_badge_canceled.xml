<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FECACA" /> <!-- Saturated Red -->
            <corners android:radius="20dp" />
            <stroke android:width="1.5dp" android:color="@color/status_canceled" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/status_canceled_bg" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="@color/status_canceled" />
        </shape>
    </item>
</selector>
